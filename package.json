{
  "name": "orion-player",
  "version": "1.0.0",
  "description": "OrionPlayer - A cross-platform music player inspired by Winamp",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "create-icon": "node scripts/create-icon.mjs"
  },
  "build": {
    "appId": "com.orionplayer.app",
    "productName": "OrionPlayer",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.music",
      "icon": "resources/icons/512x512.png",
      "target": ["dmg", "zip"]
    },
    "linux": {
      "icon": "resources/icons",
      "target": ["AppImage", "deb"],
      "category": "Audio"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ]
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.2.1",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.1"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "music-metadata": "7.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "youtube-dl-exec": "^3.0.4",
    "zustand": "^4.5.0"
  }
}
